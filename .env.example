# Relational storage
DATABASE_URL=sqlite:///./app.db

# Conversation memory
REDIS_URL=redis://localhost:6379/0

# Embeddings (local sentence-transformers model; no API key needed)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIM=384

# Chat model (Groq, OpenAI-compatible API)
GROQ_API_KEY=<your-groq-api-key>
GROQ_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=openai/gpt-oss-120b

# Vector store (Qdrant; local via docker-compose)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=documents

# SMTP (interview confirmation emails; leave blank to skip sending)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

LOG_LEVEL=info
